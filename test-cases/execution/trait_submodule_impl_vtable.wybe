# Verify a vtable implemented in a nested module is defined in the containing
# object file rather than emitted only as an external declaration.

type my_eq trait {
    abstract {test} my_equal(a:_, b:_)
}

module sub {
    impl int <: my_eq

    def {test} my_equal(a:int, b:int) {
        a = b
    }
}

def {test} requires_eq(x:my_eq, y:my_eq) {
    my_equal(x, y)
}

!println(requires_eq(1, 2))
