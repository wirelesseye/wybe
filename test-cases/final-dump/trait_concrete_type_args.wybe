# Verify trait implementations can distinguish concrete type arguments.

type printable trait {
    abstract render(x:_): string
}

type box(T) { pub box(value:T) }

impl box(int) <: printable
impl box(float) <: printable

def render(x:box(int)): string = "boxed int"
def render(x:box(float)): string = "boxed float"

!println(printable.render(box(1)))
!println(printable.render(box(3.14)))
